#!/usr/bin/env node
// stealth-browse — CDP-based browser CLI with anti-detection for Cloudflare
// Uses Node.js built-in WebSocket (Node 22+), no external dependencies.
//
// Usage:
//   stealth-browse open <url> [--proxy user:pass@host:port]
//   stealth-browse snapshot
//   stealth-browse fill <selector> <text>
//   stealth-browse click <selector>
//   stealth-browse type <text>
//   stealth-browse press <key>
//   stealth-browse select <selector> <value>
//   stealth-browse eval <js>
//   stealth-browse screenshot [path]
//   stealth-browse wait <ms | --text "pattern" | --url "pattern" | --load>
//   stealth-browse get <text|html|url|title> [selector]
//   stealth-browse scroll <up|down> [px]
//   stealth-browse close

