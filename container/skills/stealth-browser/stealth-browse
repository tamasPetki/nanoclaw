// ── Snapshot: get interactive elements ──
async function getSnapshot(client) {
  const result = await client.send('Runtime.evaluate', {
    expression: `
      (function() {
        const els = [];
        const interactiveSelectors = 'a[href], button, input, textarea, select, [role="button"], [role="link"], [role="textbox"], [contenteditable="true"], [data-testid], [onclick], [tabindex]';
        const seen = new Set();
        document.querySelectorAll(interactiveSelectors).forEach((el, i) => {
          if (seen.has(el)) return;
          seen.add(el);
          const rect = el.getBoundingClientRect();
          if (rect.width === 0 && rect.height === 0) return;
          if (el.offsetParent === null && el.tagName !== 'BODY') return;

          const tag = el.tagName.toLowerCase();
          const type = el.getAttribute('type') || '';
          const name = el.getAttribute('name') || '';
          const id = el.id || '';
          const placeholder = el.getAttribute('placeholder') || '';
          const text = (el.innerText || el.value || '').trim().slice(0, 80);
          const href = el.getAttribute('href') || '';
          const ariaLabel = el.getAttribute('aria-label') || '';
          const testId = el.getAttribute('data-testid') || '';
          const role = el.getAttribute('role') || '';

          let selector = '';
          if (testId) selector = '[data-testid="' + testId.replace(/"/g, '\\\\"') + '"]';
          else if (id) selector = '#' + CSS.escape(id);
          else if (name) selector = tag + '[name="' + name.replace(/"/g, '\\\\"') + '"]';
          else {
            const idx = Array.from(el.parentElement?.children || []).filter(c => c.tagName === el.tagName).indexOf(el);
            selector = tag + ':nth-of-type(' + (idx + 1) + ')';
            let parent = el.parentElement;
            for (let d = 0; d < 3 && parent && parent !== document.body; d++) {
              const pid = parent.id ? '#' + CSS.escape(parent.id) : parent.tagName.toLowerCase();
              selector = pid + ' > ' + selector;
              parent = parent.parentElement;
              if (parent?.id) break;
            }
          }

          els.push({
            ref: 'e' + (els.length + 1),
            tag, type, name, text, href, placeholder, ariaLabel, testId, role, selector
          });
        });
        return JSON.stringify(els);
      })()
    `,
    returnByValue: true,
  });

  return JSON.parse(result.result.value);
}

function formatSnapshot(elements) {
  const lines = ['Interactive elements:'];
  for (const el of elements) {
    let desc = `  [@${el.ref}] ${el.tag}`;
    if (el.type) desc += `[type=${el.type}]`;
    if (el.testId) desc += ` testid="${el.testId}"`;
    if (el.role && el.role !== 'button' && el.role !== 'link') desc += ` role="${el.role}"`;
    if (el.name) desc += ` name="${el.name}"`;
    if (el.placeholder) desc += ` placeholder="${el.placeholder}"`;
    if (el.ariaLabel) desc += ` aria="${el.ariaLabel}"`;
    if (el.text) desc += ` "${el.text}"`;
    if (el.href) desc += ` → ${el.href.slice(0, 60)}`;
    desc += `  {${el.selector}}`;
    lines.push(desc);
  }
  return lines.join('\n');
}

// ── Resolve @ref to CSS selector ──
async function resolveSelector(client, sel) {
  if (sel.startsWith('@e') || sel.startsWith('@E')) {
    // Get snapshot and find the ref
    const elements = await getSnapshot(client);
    const refNum = sel.replace(/^@[eE]/, '');
    const el = elements.find(e => e.ref === 'e' + refNum);
    if (!el) throw new Error(`Ref ${sel} not found. Run snapshot first.`);
    return el.selector;
  }
  return sel;
}

// ── Wait for navigation/load ──
async function waitForLoad(client, timeout = 15000) {
  const start = Date.now();
  while (Date.now() - start < timeout) {
    const result = await client.send('Runtime.evaluate', {
      expression: 'document.readyState',
      returnByValue: true,
    });
    if (result.result.value === 'complete') return;
    await new Promise(r => setTimeout(r, 300));
  }
}

// ── Get bounding box for an element selector ──
async function getBoundingBox(client, sel) {
  const result = await client.send('Runtime.evaluate', {
    expression: `
      (function() {
        const el = document.querySelector(${JSON.stringify(sel)});
        if (!el) return null;
        el.scrollIntoView({block: 'center', inline: 'center', behavior: 'instant'});
        const r = el.getBoundingClientRect();
        return {x: r.x, y: r.y, w: r.width, h: r.height,
                vw: window.innerWidth, vh: window.innerHeight};
      })()
    `,
    returnByValue: true,
  });
  return result.result.value;
}

// ── WindMouse algorithm (Ben Land port) ──
// Defeats Pearson-r linearity detection (BeCAPTCHA-Mouse paper) — used by X.
// Bezier curves are too predictable; WindMouse adds gravity + wind noise terms.
function windMousePath(sx, sy, ex, ey) {
  const G_0 = 9, W_0 = 3, M_0 = 15, D_0 = 12;
  const sqrt3 = Math.sqrt(3), sqrt5 = Math.sqrt(5);
  let G = G_0, W = W_0, M = M_0, D = D_0;
  let vx = 0, vy = 0, wx = 0, wy = 0;
  let cx = sx, cy = sy;
  const points = [];
  let safetyCounter = 0;
  while (safetyCounter++ < 5000) {
    const dx = ex - cx, dy = ey - cy;
    const dist = Math.hypot(dx, dy);
    if (dist < 1) break;
    const Wmag = Math.min(W, dist);
    if (dist >= D) {
      wx = wx / sqrt3 + (Math.random() * 2 * Wmag + 1 - Wmag) / sqrt5;
      wy = wy / sqrt3 + (Math.random() * 2 * Wmag + 1 - Wmag) / sqrt5;
    } else {
      wx /= sqrt3; wy /= sqrt3;
      if (M < 3) M = Math.random() * 3 + 3;
      else M /= sqrt5;
    }
    vx += wx + G * dx / dist;
    vy += wy + G * dy / dist;
    const vmag = Math.hypot(vx, vy);
    if (vmag > M) {
      const vclip = M / 2 + Math.random() * M / 2;
      vx = (vx / vmag) * vclip;
      vy = (vy / vmag) * vclip;
    }
    cx += vx; cy += vy;
    points.push([cx, cy]);
  }
  // Always end at exact target
  points.push([ex, ey]);
  return points;
}

// Track mouse position globally so successive moves chain naturally
let mouseX = 100 + Math.random() * 200;
let mouseY = 100 + Math.random() * 200;

async function humanMouseMove(client, ex, ey) {
  const dx = ex - mouseX, dy = ey - mouseY;
  const dist = Math.sqrt(dx * dx + dy * dy);
  if (dist < 1) return;
  const path = windMousePath(mouseX, mouseY, ex, ey);
  for (const [x, y] of path) {
    await client.send('Input.dispatchMouseEvent', {
      type: 'mouseMoved',
      x: Math.round(x),
      y: Math.round(y),
      button: 'none',
    });
    // 5-15ms per waypoint with jitter
    await sleep(rand(5, 15));
  }
  mouseX = ex;
  mouseY = ey;
}

async function humanClick(client, sel) {
  const box = await getBoundingBox(client, sel);
  if (!box) throw new Error(`Element not found: ${sel}`);
  // Click off-center but inside element (±15% of width/height from center)
  const tx = box.x + box.w * (0.35 + Math.random() * 0.30);
  const ty = box.y + box.h * (0.35 + Math.random() * 0.30);
  await humanMouseMove(client, tx, ty);
  // Hover delay before press (180-450ms)
  await sleep(gauss(290, 90, 180, 480));
  await client.send('Input.dispatchMouseEvent', {
    type: 'mousePressed', x: Math.round(tx), y: Math.round(ty),
    button: 'left', clickCount: 1,
  });
  // Press hold (40-90ms)
  await sleep(gauss(65, 18, 40, 100));
  await client.send('Input.dispatchMouseEvent', {
    type: 'mouseReleased', x: Math.round(tx), y: Math.round(ty),
    button: 'left', clickCount: 1,
  });
}

// ── Log-normal inter-key interval (Aalto 136M keystrokes paper) ──
// Mean ~150-220ms, occasional long tail. mu=5.0, sigma=0.35 → median ~148ms
function logNormalIki() {
  const u1 = Math.random() || 1e-9;
  const u2 = Math.random();
  const z = Math.sqrt(-2 * Math.log(u1)) * Math.cos(2 * Math.PI * u2);
  return Math.round(Math.exp(5.0 + 0.35 * z));
}

// Map a printable character to a CDP keyDown event payload
const KEY_TO_CODE = {
  ' ': { key: ' ',  code: 'Space',  windowsVirtualKeyCode: 32 },
  '\n': { key: 'Enter', code: 'Enter', windowsVirtualKeyCode: 13 },
};
function charToKeyEvent(char) {
  if (KEY_TO_CODE[char]) return { ...KEY_TO_CODE[char], text: char };
  // Letters
  if (/^[a-zA-Z]$/.test(char)) {
    const upper = char.toUpperCase();
    return {
      key: char,
      code: 'Key' + upper,
      windowsVirtualKeyCode: upper.charCodeAt(0),
      text: char,
    };
  }
  // Digits
  if (/^[0-9]$/.test(char)) {
    return {
      key: char,
      code: 'Digit' + char,
      windowsVirtualKeyCode: char.charCodeAt(0),
      text: char,
    };
  }
  // Punctuation/symbols — generic event with text payload
  return {
    key: char,
    code: '',
    windowsVirtualKeyCode: char.charCodeAt(0),
    text: char,
  };
}

async function dispatchKeystroke(client, char) {
  // Letters, digits, and space: full keyDown/keyUp for real keystroke dynamics.
  // Chrome/CDP has accurate built-in key codes for these.
  if (/^[a-zA-Z0-9 ]$/.test(char)) {
    const ev = charToKeyEvent(char);
    await client.send('Input.dispatchKeyEvent', { type: 'keyDown', ...ev });
    await sleep(gauss(70, 25, 35, 130));
    await client.send('Input.dispatchKeyEvent', { type: 'keyUp', ...ev });
    return;
  }
  // Punctuation and symbols: use Input.insertText which reliably emits
  // beforeinput/input events that React contenteditable (X.com, etc) accepts.
  // Full key events would need exact windowsVirtualKeyCode + code per char
  // (e.g. "." needs VK 190 + "Period", not VK 46), and getting this wrong
  // makes Chrome silently drop the character.
  await client.send('Input.insertText', { text: char });
}

// ── Human-like typing with proper keystroke dynamics ──
// Uses dispatchKeyEvent (keyDown/keyUp) so detectors that watch keystroke
// timing dynamics see real key events, not synthetic insertText injections.
async function humanType(client, text) {
  // Pre-think delay: user reads + decides (Aalto + research)
  await sleep(gauss(900, 350, 400, 1800));

  let wordCharCount = 0;
  for (let i = 0; i < text.length; i++) {
    const char = text[i];

    // ~2% chance of typo + correction (only on letters)
    if (/^[a-zA-Z]$/.test(char) && Math.random() < 0.02) {
      const wrongChar = String.fromCharCode(char.charCodeAt(0) + (Math.random() < 0.5 ? -1 : 1));
      if (/^[a-zA-Z]$/.test(wrongChar)) {
        await dispatchKeystroke(client, wrongChar);
        await sleep(gauss(220, 80, 120, 450));
        // Backspace
        await client.send('Input.dispatchKeyEvent', { type: 'keyDown', key: 'Backspace', code: 'Backspace', windowsVirtualKeyCode: 8 });
        await sleep(gauss(60, 20, 30, 110));
        await client.send('Input.dispatchKeyEvent', { type: 'keyUp',   key: 'Backspace', code: 'Backspace', windowsVirtualKeyCode: 8 });
        await sleep(gauss(120, 50, 60, 250));
      }
    }

    await dispatchKeystroke(client, char);

    // Inter-key interval — log-normal
    let delay = logNormalIki();

    // Word-end / punctuation pauses
    if (char === ' ') {
      wordCharCount = 0;
      // Micro-think every 7-12 words: 400-900ms pause
      if (Math.random() < 0.10) delay += randInt(400, 900);
    } else if ('.,!?;:'.includes(char)) {
      // 20% chance of long pause after punctuation
      if (Math.random() < 0.20) delay += randInt(600, 2000);
      else delay += randInt(150, 400);
    } else {
      wordCharCount++;
    }

    await sleep(delay);
  }

  // Post-type settle (user looks at what they wrote before clicking)
  await sleep(gauss(700, 250, 350, 1500));
}

async function humanScroll(client, direction, totalPx) {
  const sign = direction === 'up' ? -1 : 1;
  let scrolled = 0;
  while (scrolled < totalPx) {
    const step = randInt(60, 140);
    const actualStep = Math.min(step, totalPx - scrolled);
    await client.send('Input.dispatchMouseEvent', {
      type: 'mouseWheel',
      x: Math.round(mouseX),
      y: Math.round(mouseY),
      deltaX: 0,
      deltaY: sign * actualStep,
    });
    scrolled += actualStep;
    await sleep(gauss(110, 40, 50, 250));
  }
}

// ── Cookie helper ──
// X (Twitter) cookies that should be httpOnly when set on the wire
const HTTPONLY_COOKIES = new Set(['auth_token', 'twid', '_twitter_sess', 'kdt', 'att']);

async function setCookies(client, domain, kvPairs) {
  // Always set on the leading-dot form so subdomains inherit
  const dotDomain = domain.startsWith('.') ? domain : '.' + domain;
  // Special-case x.com → also set on .twitter.com (X auth still uses both)
  const domains = [dotDomain];
  if (dotDomain === '.x.com') domains.push('.twitter.com');
  if (dotDomain === '.twitter.com') domains.push('.x.com');

  const cookies = [];
  for (const d of domains) {
    for (const kv of kvPairs) {
      const eqIdx = kv.indexOf('=');
      if (eqIdx < 0) throw new Error(`Bad cookie: ${kv}`);
      const name = kv.slice(0, eqIdx);
      const value = kv.slice(eqIdx + 1);
      cookies.push({
        name,
        value,
        domain: d,
        path: '/',
        secure: true,
        httpOnly: HTTPONLY_COOKIES.has(name),
        sameSite: 'None',
      });
    }
  }
  await client.send('Network.setCookies', { cookies });
}

