        fs.writeFileSync(filePath, Buffer.from(result.data, 'base64'));
        console.log(`✓ Screenshot saved: ${filePath}`);
        break;
      }

      case 'wait': {
        if (args[1] === '--text') {
          const pattern = args[2];
          for (let i = 0; i < 60; i++) {
            const result = await client.send('Runtime.evaluate', {
              expression: `document.body.innerText.includes(${JSON.stringify(pattern)})`,
              returnByValue: true,
            });
            if (result.result.value) { console.log(`✓ Found text: "${pattern}"`); break; }
            if (i === 59) { console.error(`✗ Timeout waiting for text: "${pattern}"`); process.exit(1); }
            await new Promise(r => setTimeout(r, 500));
          }
        } else if (args[1] === '--url') {
          const pattern = args[2];
          for (let i = 0; i < 60; i++) {
            const result = await client.send('Runtime.evaluate', {
              expression: 'window.location.href', returnByValue: true,
            });
            if (result.result.value.includes(pattern)) { console.log(`✓ URL matches: ${result.result.value}`); break; }
            if (i === 59) { console.error(`✗ Timeout waiting for URL: "${pattern}"`); process.exit(1); }
            await new Promise(r => setTimeout(r, 500));
          }
        } else if (args[1] === '--load') {
          await waitForLoad(client);
          console.log('✓ Page loaded');
        } else {
          const ms = parseInt(args[1]) || 1000;
          await new Promise(r => setTimeout(r, ms));
          console.log(`✓ Waited ${ms}ms`);
        }
        break;
      }

      case 'get': {
        const what = args[1];
        const sel = args[2] ? await resolveSelector(client, args[2]) : null;
        let expr;
        switch (what) {
          case 'text':
            expr = sel
              ? `document.querySelector('${sel.replace(/'/g, "\\'")}')?.innerText || 'NOT_FOUND'`
              : 'document.body.innerText';
            break;
          case 'html':
            expr = sel
              ? `document.querySelector('${sel.replace(/'/g, "\\'")}')?.innerHTML || 'NOT_FOUND'`
              : 'document.documentElement.outerHTML';
            break;
          case 'url':
            expr = 'window.location.href';
            break;
          case 'title':
            expr = 'document.title';
            break;
          default:
            console.error(`Unknown get target: ${what}. Use: text, html, url, title`);
            process.exit(1);
        }
        const result = await client.send('Runtime.evaluate', {
          expression: expr, returnByValue: true,
        });
        console.log(result.result.value);
        break;
      }

      case 'scroll': {
        const dir = args[1] || 'down';
        const px = parseInt(args[2]) || 500;
        await humanScroll(client, dir, px);
        console.log(`✓ Scrolled ${dir} ${px}px`);
        break;
      }

      default:
        console.error(`Unknown command: ${cmd}. Run stealth-browse --help`);
        process.exit(1);
    }

    client.close();

  } catch (err) {
    console.error(`✗ Error: ${err.message}`);
    process.exit(1);
  }
}

