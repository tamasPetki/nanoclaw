      }

      case 'fill': {
        const sel = await resolveSelector(client, args[1]);
        const text = args.slice(2).join(' ');
        // Move mouse to element and click first (focus naturally)
        await humanClick(client, sel);
        // Pre-type "thinking" delay (600-1400ms) per research
        await sleep(gauss(950, 250, 600, 1500));
        // Clear existing value with Ctrl+A + Backspace
        await client.send('Input.dispatchKeyEvent', { type: 'keyDown', modifiers: 2, key: 'a', code: 'KeyA', windowsVirtualKeyCode: 65 });
        await sleep(gauss(60, 20, 30, 100));
        await client.send('Input.dispatchKeyEvent', { type: 'keyUp', modifiers: 2, key: 'a', code: 'KeyA', windowsVirtualKeyCode: 65 });
        await sleep(gauss(120, 40, 60, 200));
        await client.send('Input.dispatchKeyEvent', { type: 'keyDown', key: 'Backspace', code: 'Backspace', windowsVirtualKeyCode: 8 });
        await sleep(gauss(60, 20, 30, 100));
        await client.send('Input.dispatchKeyEvent', { type: 'keyUp', key: 'Backspace', code: 'Backspace', windowsVirtualKeyCode: 8 });
        await sleep(gauss(180, 60, 80, 350));
        await humanType(client, text);
        console.log(`✓ Filled "${text.slice(0, 60)}${text.length > 60 ? '...' : ''}" into ${args[1]}`);
        break;
      }

      case 'click': {
        const sel = await resolveSelector(client, args[1]);
        try {
          await humanClick(client, sel);
          // Random settle time
          await sleep(gauss(450, 150, 200, 900));
          console.log(`✓ Clicked ${args[1]}`);
        } catch (err) {
          console.error(`✗ ${err.message}`);
          process.exit(1);
        }
        break;
      }

      case 'type': {
        const text = args.slice(1).join(' ');
        await humanType(client, text);
        console.log(`✓ Typed "${text.slice(0, 60)}${text.length > 60 ? '...' : ''}"`);
        break;
      }

      case 'cookies': {
        // Usage: stealth-browse cookies <domain> KEY=VALUE [KEY=VALUE ...]
        const domain = args[1];
        const pairs = args.slice(2);
        if (!domain || pairs.length === 0) {
          console.error('Usage: stealth-browse cookies <domain> KEY=VALUE [KEY=VALUE ...]');
          process.exit(1);
        }
        await setCookies(client, domain, pairs);
        console.log(`✓ Set ${pairs.length} cookies for ${domain}`);
        break;
      }

      case 'hover': {
        const sel = await resolveSelector(client, args[1]);
        const box = await getBoundingBox(client, sel);
        if (!box) { console.error(`Element not found: ${args[1]}`); process.exit(1); }
        const tx = box.x + box.w / 2;
        const ty = box.y + box.h / 2;
        await humanMouseMove(client, tx, ty);
        console.log(`✓ Hovered ${args[1]}`);
        break;
      }

      case 'press': {
        const key = args[1] || 'Enter';
        const keyMap = {
          'Enter': { key: 'Enter', code: 'Enter', windowsVirtualKeyCode: 13 },
          'Tab': { key: 'Tab', code: 'Tab', windowsVirtualKeyCode: 9 },
          'Escape': { key: 'Escape', code: 'Escape', windowsVirtualKeyCode: 27 },
          'Backspace': { key: 'Backspace', code: 'Backspace', windowsVirtualKeyCode: 8 },
          'Space': { key: ' ', code: 'Space', windowsVirtualKeyCode: 32, text: ' ' },
          'ArrowDown': { key: 'ArrowDown', code: 'ArrowDown', windowsVirtualKeyCode: 40 },
          'ArrowUp': { key: 'ArrowUp', code: 'ArrowUp', windowsVirtualKeyCode: 38 },
          'ArrowLeft': { key: 'ArrowLeft', code: 'ArrowLeft', windowsVirtualKeyCode: 37 },
          'ArrowRight': { key: 'ArrowRight', code: 'ArrowRight', windowsVirtualKeyCode: 39 },
