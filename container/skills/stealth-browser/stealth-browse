// Linux x86_64 Chrome 124 — matches the JA4 fingerprint of headed Chromium on Linux
const STEALTH_UA = 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36';

// ── CDP helper ──
class CDPClient {
  constructor(wsUrl) {
    this.wsUrl = wsUrl;
    this.ws = null;
    this.id = 1;
    this.callbacks = new Map();
    this.events = [];
    this.proxyUser = null;
    this.proxyPass = null;
  }

  setProxyAuth(user, pass) {
    this.proxyUser = user;
    this.proxyPass = pass;
  }

  connect() {
    return new Promise((resolve, reject) => {
      this.ws = new WebSocket(this.wsUrl);
      this.ws.onopen = () => resolve();
      this.ws.onerror = (e) => reject(new Error(`WebSocket error: ${e.message || 'connection failed'}`));
      this.ws.onmessage = (evt) => {
        const msg = JSON.parse(evt.data);

        // Handle proxy auth challenges in real-time
        if (msg.method === 'Fetch.authRequired' && this.proxyUser) {
          this.ws.send(JSON.stringify({
            id: this.id++,
            method: 'Fetch.continueWithAuth',
            params: {
              requestId: msg.params.requestId,
              authChallengeResponse: {
                response: 'ProvideCredentials',
                username: this.proxyUser,
                password: this.proxyPass,
              },
            },
          }));
          return;
        }

        // Continue paused requests (non-auth)
        if (msg.method === 'Fetch.requestPaused') {
          this.ws.send(JSON.stringify({
            id: this.id++,
            method: 'Fetch.continueRequest',
            params: { requestId: msg.params.requestId },
          }));
          return;
        }

        if (msg.id && this.callbacks.has(msg.id)) {
          this.callbacks.get(msg.id)(msg);
          this.callbacks.delete(msg.id);
        } else if (msg.method) {
          this.events.push(msg);
        }
      };
    });
  }

  send(method, params = {}) {
    return new Promise((resolve, reject) => {
      const id = this.id++;
      const timeout = setTimeout(() => {
        this.callbacks.delete(id);
        reject(new Error(`CDP timeout: ${method}`));
      }, DEFAULT_TIMEOUT);

      this.callbacks.set(id, (msg) => {
        clearTimeout(timeout);
        if (msg.error) reject(new Error(`CDP error: ${msg.error.message}`));
        else resolve(msg.result);
      });
      this.ws.send(JSON.stringify({ id, method, params }));
    });
  }

  close() {
    if (this.ws) this.ws.close();
  }
}

// ── Xvfb launcher (virtual X display for headed Chrome) ──
function isXvfbRunning(display) {
  try {
    execSync(`xdpyinfo -display ${display}`, { stdio: 'ignore' });
    return true;
  } catch { return false; }
}

function launchXvfb() {
  if (isXvfbRunning(XVFB_DISPLAY)) return null;
  const proc = spawn('Xvfb', [
    XVFB_DISPLAY,
    '-screen', '0', XVFB_SCREEN,
    '-nolisten', 'tcp',
    '-ac',
    '+extension', 'RANDR',
    '+extension', 'GLX',
  ], {
    stdio: 'ignore',
    detached: true,
  });
  proc.unref();
  // Wait until display socket exists
  for (let i = 0; i < 30; i++) {
    if (isXvfbRunning(XVFB_DISPLAY)) return proc.pid;
    execSync('sleep 0.1');
  }
  throw new Error('Xvfb failed to start');
}

// ── Chrome launcher ──
function launchChrome(proxy) {
  // Headed Chrome on virtual display — looks like a real user, not headless
  const args = [
    '--no-sandbox',
    '--disable-dev-shm-usage',
    `--remote-debugging-port=${CDP_PORT}`,
    '--disable-blink-features=AutomationControlled',
    '--disable-features=IsolateOrigins,site-per-process,AutomationControlled',
    '--disable-infobars',
    '--no-first-run',
    '--no-default-browser-check',
    '--disable-default-apps',
    '--disable-popup-blocking',
    '--disable-background-timer-throttling',
    '--disable-renderer-backgrounding',
    '--disable-backgrounding-occluded-windows',
    '--disable-component-update',
    '--disable-domain-reliability',
    '--disable-features=TranslateUI',
    '--password-store=basic',
    '--use-mock-keychain',
    '--window-size=1920,1080',
    '--start-maximized',
    '--use-gl=angle',
    '--use-angle=swiftshader',
    '--enable-unsafe-swiftshader',
    `--user-agent=${STEALTH_UA}`,
    '--lang=en-US,en',
    '--accept-lang=en-US,en;q=0.9',
  ];

  // Allow persistent browser profile via env var (e.g. for Telegram Web session)
  if (process.env.STEALTH_USER_DATA_DIR) {
    args.push(`--user-data-dir=${process.env.STEALTH_USER_DATA_DIR}`);
  }

  if (proxy) {
    const atIdx = proxy.lastIndexOf('@');
    const hostPort = atIdx >= 0 ? proxy.slice(atIdx + 1) : proxy;
    args.push(`--proxy-server=http://${hostPort}`);
  }

  const proc = spawn(CHROME_BIN, args, {
    stdio: 'ignore',
    detached: true,
    env: { ...process.env, DISPLAY: XVFB_DISPLAY },
  });
  proc.unref();
  return proc.pid;
}

// ── Get CDP page target ──
function getCDPTargets() {
  return new Promise((resolve, reject) => {
    http.get(`http://localhost:${CDP_PORT}/json`, (res) => {
      let data = '';
      res.on('data', (c) => data += c);
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch (e) { reject(new Error('Failed to parse CDP targets')); }
      });
    }).on('error', reject);
  });
}

async function waitForChrome(maxWait = 10000) {
  const start = Date.now();
  while (Date.now() - start < maxWait) {
    try {
      await getCDPTargets();
      return;
    } catch {
      await new Promise(r => setTimeout(r, 300));
    }
  }
  throw new Error('Chrome failed to start');
}

// ── State management ──
function loadState() {
  try { return JSON.parse(fs.readFileSync(STATE_FILE, 'utf8')); }
  catch { return null; }
}

function saveState(state) {
  fs.writeFileSync(STATE_FILE, JSON.stringify(state, null, 2));
}

function clearState() {
  try { fs.unlinkSync(STATE_FILE); } catch {}
}

// ── Check if Chrome is alive ──
function isChromeRunning(pid) {
  try { process.kill(pid, 0); return true; }
  catch { return false; }
}

// ── Connect to existing or launch new Chrome ──
async function getClient(proxy) {
  let state = loadState();

  // Check if existing Chrome is running
  if (state && state.pid && isChromeRunning(state.pid)) {
    try {
      const targets = await getCDPTargets();
      const page = targets.find(t => t.type === 'page' && t.id === state.pageId)
                || targets.find(t => t.type === 'page');
      if (page) {
        const client = new CDPClient(page.webSocketDebuggerUrl);
        await client.connect();
        // Restore proxy auth on reconnect — Fetch.enable is per-session,
        // so it must be re-enabled on every new WebSocket connection
        if (state.proxyUser) {
          client.setProxyAuth(state.proxyUser, state.proxyPass);
          await client.send('Fetch.enable', {
            patterns: [{ urlPattern: '*', requestStage: 'Request' }],
            handleAuthRequests: true,
          });
        }
        return { client, state, isNew: false };
      }
    } catch {}
  }

  // Launch new Chrome
  if (state && state.pid) {
    try { process.kill(state.pid, 'SIGKILL'); } catch {}
    await new Promise(r => setTimeout(r, 500));
  }

  // Ensure Xvfb is running first
  const xvfbPid = launchXvfb();

  const pid = launchChrome(proxy);
  await waitForChrome();

  const targets = await getCDPTargets();
  const page = targets.find(t => t.type === 'page');
  if (!page) throw new Error('No page target found');

  const client = new CDPClient(page.webSocketDebuggerUrl);
  await client.connect();

  // Enable required domains
  await client.send('Page.enable');
  await client.send('Runtime.enable');
  await client.send('Network.enable');

  // Inject stealth patches (fires before every page JS)
  await client.send('Page.addScriptToEvaluateOnNewDocument', { source: STEALTH_SCRIPT });

  // Override UA at network level — Linux persona to match TLS JA4
  await client.send('Emulation.setUserAgentOverride', {
    userAgent: STEALTH_UA,
    platform: 'Linux x86_64',
    acceptLanguage: 'en-US,en;q=0.9',
    userAgentMetadata: {
      brands: [
        { brand: 'Chromium', version: '124' },
        { brand: 'Google Chrome', version: '124' },
        { brand: 'Not-A.Brand', version: '99' },
      ],
      fullVersion: '124.0.6367.207',
      platform: 'Linux',
      platformVersion: '6.5.0',
      architecture: 'x86',
      model: '',
      mobile: false,
    },
  });

  // Force English language headers on every request (overrides IP geolocation)
  await client.send('Network.setExtraHTTPHeaders', {
    headers: { 'Accept-Language': 'en-US,en;q=0.9' },
  });

  // Pretend to be in a US timezone (matches en-US)
  try {
    await client.send('Emulation.setTimezoneOverride', { timezoneId: 'America/New_York' });
  } catch (e) {}

  // Handle proxy auth if credentials provided
  if (proxy && proxy.includes('@')) {
    const atIdx = proxy.lastIndexOf('@');
    const creds = proxy.slice(0, atIdx);
    const colonIdx = creds.indexOf(':');
    const username = creds.slice(0, colonIdx);
    const password = creds.slice(colonIdx + 1);
    // Set proxy credentials on client for real-time inline auth handling
    client.setProxyAuth(username, password);
    await client.send('Fetch.enable', {
      patterns: [{ urlPattern: '*', requestStage: 'Request' }],
      handleAuthRequests: true,
    });
    state = { pid, xvfbPid, pageId: page.id, proxy, proxyUser: username, proxyPass: password };
  } else {
    state = { pid, xvfbPid, pageId: page.id, proxy: proxy || null };
  }

  saveState(state);
  return { client, state, isNew: true };
}

