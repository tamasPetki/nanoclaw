{
  "mcpServers": {
    "withings": {
      "command": "/bin/bash",
      "args": [
        "/opt/mcp-servers/withings/run.sh"
      ],
      "env": {
        "WITHINGS_CLIENT_ID": "${WITHINGS_CLIENT_ID}",
        "WITHINGS_CLIENT_SECRET": "${WITHINGS_CLIENT_SECRET}",
        "WITHINGS_TOKEN_PATH": "/workspace/extra/.withings/withings_tokens.json"
      }
    },
    "email-pietscarlet": {
      "command": "mcp-email-server",
      "args": [
        "stdio"
      ],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "pietscarlet",
        "MCP_EMAIL_SERVER_FULL_NAME": "\"PietScarlet Kft.\"",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "hello@pietscarlet.hu",
        "MCP_EMAIL_SERVER_IMAP_HOST": "mail.pietscarlet.hu",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "mail.pietscarlet.hu",
        "MCP_EMAIL_SERVER_SMTP_PORT": "587",
        "MCP_EMAIL_SERVER_SMTP_SSL": "false",
        "MCP_EMAIL_SERVER_SMTP_START_SSL": "true",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "true",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true",
        "MCP_EMAIL_SERVER_PASSWORD": "${PIETSCARLET_EMAIL_PASSWORD}"
      }
    },
    "email-lupaobol": {
      "command": "mcp-email-server",
      "args": [
        "stdio"
      ],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "lupaobol",
        "MCP_EMAIL_SERVER_FULL_NAME": "\"Lupa Öböl Kft.\"",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "hello@lupaobolstrand.hu",
        "MCP_EMAIL_SERVER_IMAP_HOST": "s3.dchosting.hu",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "s3.dchosting.hu",
        "MCP_EMAIL_SERVER_SMTP_PORT": "465",
        "MCP_EMAIL_SERVER_SMTP_SSL": "true",
        "MCP_EMAIL_SERVER_SMTP_START_SSL": "false",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "true",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true",
        "MCP_EMAIL_SERVER_PASSWORD": "${LUPAOBOL_EMAIL_PASSWORD}"
      }
    },
    "email-trinkenessen": {
      "command": "mcp-email-server",
      "args": [
        "stdio"
      ],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "trinkenessen",
        "MCP_EMAIL_SERVER_FULL_NAME": "\"Trinken Essen Kft.\"",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "hello@trinkenessen.eu",
        "MCP_EMAIL_SERVER_IMAP_HOST": "s3.dchosting.hu",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "s3.dchosting.hu",
        "MCP_EMAIL_SERVER_SMTP_PORT": "465",
        "MCP_EMAIL_SERVER_SMTP_SSL": "true",
        "MCP_EMAIL_SERVER_SMTP_START_SSL": "false",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "true",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true",
        "MCP_EMAIL_SERVER_PASSWORD": "${TRINKENESSEN_EMAIL_PASSWORD}"
      }
    },
    "google-calendar": {
      "command": "npx",
      "args": [
        "-y",
        "@cocal/google-calendar-mcp"
      ],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/workspace/extra/google-oauth/gcp-oauth.keys.json",
        "GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/workspace/extra/google-oauth/gcal_tokens.json",
        "NO_PROXY": "googleapis.com,.googleapis.com,oauth2.googleapis.com,www.googleapis.com,docs.googleapis.com,sheets.googleapis.com,slides.googleapis.com,drive.google.com",
        "no_proxy": "googleapis.com,.googleapis.com,oauth2.googleapis.com,www.googleapis.com,docs.googleapis.com,sheets.googleapis.com,slides.googleapis.com,drive.google.com",
        "HTTPS_PROXY": "",
        "HTTP_PROXY": "",
        "https_proxy": "",
        "http_proxy": ""
      }
    },
    "google-drive": {
      "command": "npx",
      "args": [
        "-y",
        "@piotr-agier/google-drive-mcp"
      ],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/workspace/extra/google-oauth/gcp-oauth.keys.json",
        "GOOGLE_DRIVE_MCP_TOKEN_PATH": "/workspace/extra/google-oauth/drive_tokens.json",
        "NO_PROXY": "googleapis.com,.googleapis.com,oauth2.googleapis.com,www.googleapis.com,docs.googleapis.com,sheets.googleapis.com,slides.googleapis.com,drive.google.com",
        "no_proxy": "googleapis.com,.googleapis.com,oauth2.googleapis.com,www.googleapis.com,docs.googleapis.com,sheets.googleapis.com,slides.googleapis.com,drive.google.com",
        "HTTPS_PROXY": "",
        "HTTP_PROXY": "",
        "https_proxy": "",
        "http_proxy": ""
      }
    },
    "quick": {
      "command": "node",
      "args": [
        "/opt/mcp-servers/quick/index.js"
      ],
      "env": {
        "QUICK_API_TOKEN": "placeholder-onecli-overrides"
      }
    },
    "ticktick": {
      "command": "/bin/bash",
      "args": [
        "/opt/mcp-servers/ticktick/run.sh"
      ],
      "env": {
        "TICKTICK_ACCESS_TOKEN": "${TICKTICK_ACCESS_TOKEN}",
        "TICKTICK_CLIENT_ID": "${TICKTICK_CLIENT_ID}",
        "TICKTICK_CLIENT_SECRET": "${TICKTICK_CLIENT_SECRET}",
        "TICKTICK_V2_SESSION_TOKEN": "${TICKTICK_V2_SESSION_TOKEN}",
        "NO_PROXY": "api.ticktick.com,ticktick.com,.ticktick.com",
        "HTTPS_PROXY": "",
        "HTTP_PROXY": ""
      }
    }
  },
  "packages": {
    "apt": [],
    "npm": []
  },
  "additionalMounts": [
    {
      "hostPath": "/root/nanoclaw-v2/groups/hub/.mcp-auth",
      "containerPath": ".mcp-auth",
      "readonly": false
    },
    {
      "hostPath": "/root/nanoclaw-v2/groups/hub/.withings",
      "containerPath": ".withings",
      "readonly": false
    },
    {
      "hostPath": "/root/nanoclaw-v2/data/shared/google-oauth",
      "containerPath": "google-oauth",
      "readonly": false
    },
    {
      "hostPath": "/root/nanoclaw-v2/data/v2-sessions/ag-worker",
      "containerPath": "worker-sessions",
      "readonly": true
    },
    {
      "hostPath": "/root/data/gdrive-pietscarlet",
      "containerPath": "pietscarlet-drive",
      "readonly": true
    },
    {
      "hostPath": "/root/nanoclaw-v2/data/v2-sessions/e6fdddad-f8a2-4476-9219-5864e9f4e79b",
      "containerPath": "stokes-sessions",
      "readonly": true
    }
  ],
  "skills": [
    "agent-browser",
    "document-fill",
    "email-assistant",
    "google-drive-write",
    "humanizer",
    "inline-ui",
    "mnemon",
    "ocr-and-documents",
    "onecli-gateway",
    "pdf-filler",
    "pdf-reader",
    "quick-integration",
    "self-customize",
    "self-improvement",
    "skill-authoring",
    "status",
    "ticktick",
    "welcome",
    "whatsapp-formatting",
    "wiki"
  ],
  "provider": "claude",
  "groupName": "Hub",
  "assistantName": "Hub",
  "agentGroupId": "ag-hub",
  "model": "claude-opus-4-8[1m]",
  "effort": "xhigh"
}
