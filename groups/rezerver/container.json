{
  "mcpServers": {
    "rezerver-email": {
      "command": "uvx",
      "args": [
        "mcp-email-server@latest",
        "stdio"
      ],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "rezerver",
        "MCP_EMAIL_SERVER_FULL_NAME": "Dani @ Rezerver",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "dani@rezerver.com",
        "MCP_EMAIL_SERVER_IMAP_HOST": "imap.zoho.eu",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "smtp.zoho.eu",
        "MCP_EMAIL_SERVER_SMTP_PORT": "587",
        "MCP_EMAIL_SERVER_SMTP_SSL": "false",
        "MCP_EMAIL_SERVER_SMTP_START_SSL": "true",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "false",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true",
        "MCP_EMAIL_SERVER_PASSWORD": "${REZERVER_EMAIL_PASSWORD}"
      }
    }
  },
  "packages": {
    "apt": [],
    "npm": []
  },
  "additionalMounts": [],
  "model": "opus",
  "effort": "low"
}
