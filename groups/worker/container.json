{
  "mcpServers": {
    "bulltrapp-email": {
      "command": "mcp-email-server",
      "args": [
        "stdio"
      ],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "bulltrapp",
        "MCP_EMAIL_SERVER_FULL_NAME": "\"Lloyd @ BullTrapp\"",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "lloyd@bulltrapp.com",
        "MCP_EMAIL_SERVER_IMAP_HOST": "imap.zoho.eu",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "smtp.zoho.eu",
        "MCP_EMAIL_SERVER_SMTP_PORT": "587",
        "MCP_EMAIL_SERVER_SMTP_SSL": "false",
        "MCP_EMAIL_SERVER_SMTP_START_SSL": "true",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "false",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true",
        "MCP_EMAIL_SERVER_PASSWORD": "${BULLTRAPP_EMAIL_PASSWORD}"
      }
    },
    "rezerver-email": {
      "command": "mcp-email-server",
      "args": [
        "stdio"
      ],
      "env": {
        "MCP_EMAIL_SERVER_ACCOUNT_NAME": "rezerver",
        "MCP_EMAIL_SERVER_FULL_NAME": "\"Dani @ Rezerver\"",
        "MCP_EMAIL_SERVER_EMAIL_ADDRESS": "dani@rezerver.com",
        "MCP_EMAIL_SERVER_IMAP_HOST": "imap.zoho.eu",
        "MCP_EMAIL_SERVER_IMAP_PORT": "993",
        "MCP_EMAIL_SERVER_SMTP_HOST": "smtp.zoho.eu",
        "MCP_EMAIL_SERVER_SMTP_PORT": "587",
        "MCP_EMAIL_SERVER_SMTP_SSL": "false",
        "MCP_EMAIL_SERVER_SMTP_START_SSL": "true",
        "MCP_EMAIL_SERVER_ENABLE_ATTACHMENT_DOWNLOAD": "false",
        "MCP_EMAIL_SERVER_SAVE_TO_SENT": "true",
        "MCP_EMAIL_SERVER_PASSWORD": "${REZERVER_EMAIL_PASSWORD}"
      }
    },
    "youtube-transcript": {
      "command": "npx",
      "args": [
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ]
    }
  },
  "packages": {
    "apt": [],
    "npm": []
  },
  "additionalMounts": [
    {
      "hostPath": "/root/nanoclaw-v2/groups/worker/.mcp-auth",
      "containerPath": ".mcp-auth",
      "readonly": false
    }
  ],
  "skills": "all",
  "provider": "claude",
  "groupName": "Worker",
  "assistantName": "Worker",
  "agentGroupId": "ag-worker",
  "model": "claude-opus-4-8[1m]",
  "effort": "xhigh"
}
