{
  "mcpServers": {
    "youtube-transcript": {
      "command": "npx",
      "args": [
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ]
    },
    "quick": {
      "command": "node",
      "args": [
        "/opt/mcp-servers/quick/index.js"
      ],
      "env": {
        "QUICK_API_TOKEN": "placeholder-onecli-overrides"
      }
    },
    "todoist": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://ai.todoist.net/mcp"
      ],
      "env": {}
    },
    "google-calendar": {
      "command": "npx",
      "args": [
        "-y",
        "@cocal/google-calendar-mcp"
      ],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "/workspace/extra/google-oauth/gcp-oauth.keys.json",
        "GOOGLE_CALENDAR_MCP_TOKEN_PATH": "/workspace/extra/google-oauth/gcal_tokens.json"
      }
    }
  },
  "packages": {
    "apt": [],
    "npm": []
  },
  "additionalMounts": [
    {
      "hostPath": "/root/nanoclaw-v2/groups/asszisztens/.mcp-auth",
      "containerPath": ".mcp-auth",
      "readonly": false
    },
    {
      "hostPath": "/root/nanoclaw-v2/data/shared/google-oauth",
      "containerPath": "google-oauth",
      "readonly": false
    }
  ],
  "model": "opus",
  "effort": "low",
  "skills": "all",
  "groupName": "Asszisztens",
  "assistantName": "Asszisztens",
  "agentGroupId": "ag-asszisztens"
}